{
  "name": "xenra",
  "license": "MIT",
  "scripts": {
    "build": "bunx nx run-many -t build --output-style=stream --verbose",
    "test": "bun test --path-ignore-patterns '**/dist/**'",
    "check": "bun install && bun run build && bun run lint && bun run test",
    "fmt": "bunx @biomejs/biome check --write",
    "lint": "bunx @biomejs/biome check .",
    "npm:publish": "bunx nx run-many -t nx-release-publish --output-style=stream --verbose",
    "commit": "bunx commit"
  },
  "nx": {
    "includedScripts": [
      "check",
      "fmt",
      "commit",
      "lint"
    ]
  },
  "private": true,
  "dependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.12",
    "arktype": "^2.2.0"
  },
  "devDependencies": {
    "@nx/esbuild": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/node": "22.6.5",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
    "esbuild": "^0.27.0",
    "nx": "22.6.5",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
